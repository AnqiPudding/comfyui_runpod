# Local proxy
LOCAL_COMFY_URL=http://127.0.0.1:8189
LOCAL_OUTPUT_DIR=output
PROXY_HOST=127.0.0.1
PROXY_PORT=8188

# RunPod
RUNPOD_API_KEY=replace-me
RUNPOD_ENDPOINT_ID=replace-me
# Optional full URL override:
# RUNPOD_ENDPOINT=https://api.runpod.ai/v2/replace-me
RUNPOD_TIMEOUT=900
RUNPOD_POLL_INTERVAL=5

# Worker
COMFY_JOB_TIMEOUT=900
COMFY_STARTUP_TIMEOUT=180
RETURN_IMAGES=base64
