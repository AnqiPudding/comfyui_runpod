# Local proxy
LOCAL_COMFY_URL=http://127.0.0.1:8189
LOCAL_OUTPUT_DIR=output
PROXY_HOST=127.0.0.1
PROXY_PORT=8188

# RunPod request tuning. Endpoint ID and API key are saved from /runpod/settings.
RUNPOD_TIMEOUT=900
RUNPOD_POLL_INTERVAL=5

# Worker
COMFY_JOB_TIMEOUT=900
COMFY_STARTUP_TIMEOUT=180
RETURN_IMAGES=base64
